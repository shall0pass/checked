# =========================
# Build stage
# =========================

FROM node:22-bookworm-slim AS builder
WORKDIR /app
RUN apt-get update && apt-get install -y \
	automake \
	autoconf \
	build-essential \
	pkg-config \
	libtool \
	&& rm -rf /var/lib/apt/lists/*
RUN npm install -g pnpm
# Copy workspace config, manifests, and source
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY web ./web
COPY server ./server
RUN pnpm install --no-frozen-lockfile
# Build web (vite) and server (tsc)
RUN pnpm --filter @checked/web build
RUN pnpm --filter @checked/server build

# =========================
# Production stage
# =========================

FROM node:22-bookworm-slim
WORKDIR /app
RUN npm install -g pnpm
# Copy package manifests and workspace config
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY web/package.json ./web/
COPY server/package.json ./server/
RUN pnpm install --prod --no-frozen-lockfile
# Copy built artifacts and node_modules from builder
COPY --from=builder /app/web/dist ./web/dist
COPY --from=builder /app/server/dist ./server/dist
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/web/node_modules ./web/node_modules
COPY --from=builder /app/server/node_modules ./server/node_modules

# Copy web source and config files needed for rebuild (preview runs vite preview)
COPY web/src ./web/src
COPY web/vite.config.ts ./web/
COPY web/vite.config.d.ts ./web/
COPY web/index.html ./web/
COPY web/wrangler.jsonc ./web/
COPY web/tsconfig.json ./web/
COPY web/tsconfig.node.json ./web/
COPY web/tailwind.config.ts ./web/
COPY web/postcss.config.js ./web/
COPY web/svelte.config.js ./web/
COPY web/components.json ./web/

EXPOSE 5173
EXPOSE 8080

# Start both the web preview server and the sync server
CMD ["sh", "-c", "pnpm --filter @checked/web preview & pnpm --filter @checked/server preview"]
